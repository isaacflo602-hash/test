local NovaUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/isaacflo602-hash/NovaUILibrary/main/Nova.lua"))()

local Window = NovaUI:CreateWindow("Nova Engine")
local MainTab = Window:CreateTab("Player")

local lp = game:GetService("Players").LocalPlayer
local targetSpeed = 16
local targetJump = 50

task.spawn(function()
	while task.wait(0.1) do
		if lp.Character then
			local humanoid = lp.Character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid.WalkSpeed = targetSpeed
				
				if humanoid.UseJumpPower then
					humanoid.JumpPower = targetJump
				else
					humanoid.JumpHeight = (targetJump ^ 2) / (2 * game.Workspace.Gravity)
				end
			end
		end
	end
end)

MainTab:CreateSlider("WalkSpeed", 16, 250, 16, function(value)
	targetSpeed = value
end)

MainTab:CreateSlider("JumpPower", 50, 300, 50, function(value)
	targetJump = value
end)
