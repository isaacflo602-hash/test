local function showMobileError(msg)
	local sg = Instance.new("ScreenGui")
	sg.Name = "NovaDebug"
	sg.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
	
	local f = Instance.new("Frame")
	f.Size = UDim2.new(0, 400, 0, 150)
	f.Position = UDim2.new(0.5, -200, 0.5, -75)
	f.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	f.Parent = sg
	
	local t = Instance.new("TextLabel")
	t.Size = UDim2.new(1, -20, 1, -20)
	t.Position = UDim2.new(0, 10, 0, 10)
	t.BackgroundTransparency = 1
	t.TextColor3 = Color3.fromRGB(255, 75, 75)
	t.TextSize = 14
	t.TextWrapped = true
	t.TextXAlignment = Enum.TextXAlignment.Left
	t.TextYAlignment = Enum.TextYAlignment.Top
	t.Text = msg
	t.Parent = f
end

local success, err = pcall(function()
	local RawURL = "https://raw.githubusercontent.com/isaacflo602-hash/NovaUILibrary/main/Nova.lua"
	local source = game:HttpGet(RawURL)
	local NovaUI = loadstring(source)()

	local Window = NovaUI:CreateWindow("Nova Test")
	local Tab1 = Window:CreateTab("Combat")
	local Tab2 = Window:CreateTab("Visuals")
	local Tab3 = Window:CreateTab("Movement")

	Tab1:CreateButton("Kill Aura", function()
		print("Kill Aura activated")
	end)

	Tab2:CreateToggle("ESP Boxes", false, function(state)
		print("ESP state:", state)
	end)

	Tab3:CreateSlider("WalkSpeed", 16, 250, 16, function(value)
		print("WalkSpeed changed to:", value)
	end)
end)

if not success then
	showMobileError("NovaUI Error:\n" .. tostring(err))
end
