print("--- Nova UI Diagnostic Start ---")

local success, NovaUI = pcall(function()
    return loadstring(game:HttpGet("https://raw.githubusercontent.com/isaacflo602-hash/NovaUILibrary/main/Nova.lua"))()
end)

if not success or not NovaUI then
    print("❌ ERROR: Failed to download or parse the Nova library from GitHub!")
    print("Reason: ", tostring(NovaUI))
    return
else
    print("✅ SUCCESS: Nova Library downloaded perfectly!")
end

local WindowSuccess, Window = pcall(function()
    return NovaUI:CreateWindow("Nova Engine")
end)

if not WindowSuccess or not Window then
    print("❌ ERROR: Failed while running :CreateWindow()")
    return
else
    print("✅ SUCCESS: Window created!")
end

local TabSuccess, MainTab = pcall(function()
    return Window:CreateTab("Player")
end)

if not TabSuccess or not MainTab then
    print("❌ ERROR: Failed while running :CreateTab()")
    return
else
    print("✅ SUCCESS: Tab created!")
end

-- Variables for character stats
local lp = game:GetService("Players").LocalPlayer
local targetSpeed = 16
local targetJump = 50

-- Background Loop
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if lp.Character then
                local humanoid = lp.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid.WalkSpeed = targetSpeed
                    if humanoid.UseJumpPower then
                        humanoid.JumpPower = targetJump
                    else
                        humanoid.JumpHeight = (targetJump ^ 2) / (2 * game.Workspace.Gravity)
                    end
                end
            end
        end)
    end
end)

-- Create Sliders
pcall(function()
    MainTab:CreateSlider("WalkSpeed", 16, 250, 16, function(value)
        targetSpeed = value
    end)
    print("✅ SUCCESS: WalkSpeed Slider added!")
end)

pcall(function()
    MainTab:CreateSlider("JumpPower", 50, 300, 50, function(value)
        targetJump = value
    end)
    print("✅ SUCCESS: JumpPower Slider added!")
end)

print("--- Nova UI Diagnostic End ---")
